#:import utils kivy.utils

WindowManager:
    #Inicio:
    #pantalla1:
    #pantalla2:
    #password:
    #correcto:
    Fade:

<Background_label@Label>:
    background_color: 0,0,0,0
    width: self.texture_size[0]
    size_hint: None, 0.5

    canvas.before:
        Color:
            rgba: self.background_color
        Rectangle:
            size: self.size
            pos: self.pos


<Fade>:
    name: "fade"

    Button:
        id: btn_prueba
        text: "prueba"
        font_size: "18"
        size: (150,150)
        size_hint: None, 0.25
        color: "#8a63ff"
        background_color: 1,1,1, root.opacidad
        on_press: root.fade()

<Inicio>:
    name: "main"
    
    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'fondo_omorii.jpg'   


    GridLayout:
        cols: 1

        Label:
            markup: True
            text: "inicio jwjjeje"
            color: "#cfa8ff"
            font_size : 18

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            Image:
                source: "startest.gif"
                anim_delay: 0.1
                size_hint: None, None
                size: 300,300

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            Button:
                id: btn_inicio
                text: "ir a pantalla 1"
                font_size: "18"
                size: (150, 150)
                size_hint : None, 0.20
                color: "#8a63ff"
                background_color: utils.get_color_from_hex("#3e0989")
                background_normal: ''
                on_press : app.iniciar()
                on_release:
                    app.root.current = "pantalla1"
                    root.manager.transition.direction = "left"





<pantalla1>:
    name: "pantalla1"
    

    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'omorii_basil.jpg'

  

    GridLayout:
        cols: 1

        Label:
            markup: True
            text: "pantalla2 jwjjeje"
            color: "#ddc1ff"
            font_size : 18

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            Button:
                id: btn_1
                text: "un picnic?"
                font_size: "18"
                size_hint : 0.15, 0.15
                color: "#c244fc"
                background_color: utils.get_color_from_hex("#3e0989")
                background_normal: ''
                on_release:
                    app.root.current = "pantalla2"
                    root.manager.transition.direction = "right"


<pantalla2>:
    name: "pantalla2"
   
    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'omorii_picnic.jpg'

  

    GridLayout:
        cols: 1

        Label:
            markup: True
            
            color: "#ddc1ff"
            font_size : 18

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'bottom'

            BoxLayout:
                orientation: "horizontal"
                padding: 30
                spacing: 10


                Button:
                    id: btn_2
                    text: ":3"
                    font_size: "18"
                    size_hint : 0.15, 0.15
                    color: "#c244fc"
                    background_color: utils.get_color_from_hex("#3e0989")
                    background_normal: ''
                    on_press: root.clicks()

                Button:
                    id: btn_3
                    text: "regresar?"
                    font_size: "18"
                    size_hint : 0.15, 0.15
                    color: "#ae00ff"
                    background_color: utils.get_color_from_hex("#3e0989")
                    background_normal: ''
                    on_release:
                        app.root.current = "main"
                        root.manager.transition.direction = "right"


<password>:
    name: "password"

    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'blackomorii.jpg'

    GridLayout:
        cols: 1

        Label:
            markup: True
            text: ''
            color: "#ffffff"
            font_size : 24

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'
            BoxLayout:
                orientation: "horizontal"
                padding: 30
                spacing: 10


                Button:
                    id: btn_4
                    text: "siguiente"
                    font_size: "18"
                    size_hint : 0.15, 0.15
                    color: "#ffffff"
                    background_color: utils.get_color_from_hex("#000000")
                    background_normal: ''
                    on_release:
                        app.root.current = "correcto"
                        root.manager.transition.direction = "left"

<correcto>:
    name: "correcto"

    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'correctomorii.jpg'

    GridLayout:
        cols: 1
