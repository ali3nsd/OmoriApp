#:import utils kivy.utils





WindowManager:
    Inicio:
    pantalla1:
    pantalla2


<Background_label@Label>:
    background_color: 0,0,0,0
    width: self.texture_size[0]
    size_hint: None, 0.5

    canvas.before:
        Color:
            rgba: self.background_color
        Rectangle:
            size: self.size
            pos: self.pos







<Inicio>:
    name: "main"
    




    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'fondo_omorii.jpg'   

    
    GridLayout:
        cols: 1

        Label:
            markup: True
            text: "inicio jwjjeje"
            color: "#cfa8ff"
            font_size : 18

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            Background_label:

                text: "etiquetaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
                color: "#6622ae"
                background_color: utils.get_color_from_hex("#8154c1")





        
            
        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'
            

            Button:
                id: btn_inicio
                text: "ir a pantalla 1"
                font_size: "18"
                size: (150, 150)
                size_hint : None, 0.20
                color: "#8a63ff"
                background_color: utils.get_color_from_hex("#3e0989")
                background_normal: ''
                on_press : app.iniciar()
                on_release:
                    app.root.current = "pantalla1"
                    root.manager.transition.direction = "left"





<pantalla1>:
    name: "pantalla1"
    

    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'omorii_basil.jpg'

  

    GridLayout:
        cols: 1

        Label:
            markup: True
            text: "pantalla2 jwjjeje"
            color: "#ddc1ff"
            font_size : 18

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            Button:
                id: btn_1
                text: "un picnic?"
                font_size: "18"
                size_hint : 0.15, 0.15
                color: "#c244fc"
                background_color: utils.get_color_from_hex("#3e0989")
                background_normal: ''
                on_release:
                    app.root.current = "pantalla2"
                    root.manager.transition.direction = "right"


<pantalla2>:
    name: "pantalla2"
    
    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'omorii_picnic.jpg'

  

    GridLayout:
        cols: 1

        Label:
            markup: True
        
            color: "#ddc1ff"
            font_size : 18

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'bottom'

            BoxLayout:
                orientation: "horizontal"
                padding: 30
                spacing: 10


                Button:
                    id: btn_2
                    text: ":3"
                    font_size: "18"
                    size_hint : 0.15, 0.15
                    color: "#c244fc"
                    background_color: utils.get_color_from_hex("#3e0989")
                    background_normal: ''
            
                Button:
                    id: btn_3
                    text: "regresar?"
                    font_size: "18"
                    size_hint : 0.15, 0.15
                    color: "#ae00ff"
                    background_color: utils.get_color_from_hex("#3e0989")
                    background_normal: ''
                    on_release:
                        app.root.current = "main"
                        root.manager.transition.direction = "right"
