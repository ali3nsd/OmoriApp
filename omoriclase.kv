#:import utils kivy.utils
#:import FadeTransition kivy.uix.screenmanager.FadeTransition

WindowManager:
    transition: FadeTransition()
    duration: 0.40
    Inicio:
    pantalla1:
    pantalla2:
    password:
    correcto:
    error:
    

<Background_label@Label>:
    background_color: 0,0,0,0
    width: self.texture_size[0]
    size_hint: None, 0.5

    canvas.before:
        Color:
            rgba: self.background_color
        Rectangle:
            size: self.size
            pos: self.pos




<Inicio>:
    name: "main"
    

    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'fondo_omorii.jpg'


    BoxLayout:
        orientation: 'vertical'
        padding: 0


        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'


            #Video:
                #size_hint: None, None
                #size : (600, 400)
                #source: "kangelgif.gif"
                #state: 'play'
                #options: {'allow_stretch': True,'eos': 'loop'}
                
        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'bottom'

            Button:
                id: btn_inicio
                text: "ir a pantalla 1"
                font_size: "18"
                size: (200,70)
                size_hint : None, None
                color: "#8a63ff"
                background_color: utils.get_color_from_hex("#3e0989")
                background_normal: ''
                on_press : app.iniciar()
                on_release:
                    app.root.current = "pantalla1"
                    root.manager.transition.direction = "left"




        



<pantalla1>:
    name: "pantalla1"
    

    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'omorii_basil.jpg'

  

    GridLayout:
        cols: 1

        Label:
            markup: True
            text: "pantalla2 jwjjeje"
            color: "#ddc1ff"
            font_size : 18

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            Button:
                id: btn_1
                text: "un picnic?"
                font_size: "18"
                size_hint : 0.15, 0.15
                color: "#c244fc"
                background_color: utils.get_color_from_hex("#3e0989")
                background_normal: ''
                on_release:
                    app.root.current = "pantalla2"
                    root.manager.transition.direction = "right"


<pantalla2>:
    name: "pantalla2"
   
    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'omorii_picnic.jpg'

  

    GridLayout:
        cols: 1

        Label:
            markup: True
            
            color: "#ddc1ff"
            font_size : 18

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'bottom'

            BoxLayout:
                orientation: "horizontal"
                padding: 30
                spacing: 10


                Button:
                    id: btn_2
                    text: ":3"
                    font_size: "18"
                    size_hint : 0.15, 0.15
                    color: "#c244fc"
                    background_color: utils.get_color_from_hex("#3e0989")
                    background_normal: ''
                    on_press: root.clicks()

                Button:
                    id: btn_3
                    text: "regresar?"
                    font_size: "18"
                    size_hint : 0.15, 0.15
                    color: "#ae00ff"
                    background_color: utils.get_color_from_hex("#3e0989")
                    background_normal: ''
                    on_release:
                        app.root.current = "main"
                        root.manager.transition.direction = "right"


<password>:
    name: "password"

    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'blackomorii.jpg'


        
    BoxLayout:
        orientation: "vertical"
        padding: 30
        spacing: 10

        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'


            Label:
                id: label_password
                markup: True
                text: "Ingresa el código"
                color: "#ffffff"
                font_size : 24


        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'

            TextInput:
                id: input_password
                text: ""
                size_hint: 0.3, 0.3
                multiline: False
                password: False
                font_size: 19


        AnchorLayout:
            anchor_x: 'center'
            anchor_y: 'center'
            
            Button:
                id: btn_4
                text: "siguiente"
                font_size: "18"
                size_hint : 0.15, 0.15
                color: "#ffffff"
                background_color: utils.get_color_from_hex("#000000")
                background_normal: ''
                on_press:
                    root.check(label_password, input_password)
                    input_password.text = " "
<correcto>:
    name: "correcto"

    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'correctomorii.jpg'

    GridLayout:
        cols: 1


<error>:
    name: "error"

    canvas.before:
        Rectangle:
            pos: self.pos
            size: self.size
            source: 'omorii_incorrecto.jpg'

    GridLayout:
        cols: 1
